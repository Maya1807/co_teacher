%%{init: {
  'theme': 'base',
  'themeVariables': {
    'background': '#FFFFFF',
    'lineColor': '#78909C',
    'fontFamily': 'Inter, -apple-system, sans-serif',
    'fontSize': '15px'
  }
}}%%

flowchart TB
    UI["🧑‍🏫 <b>Teacher UI</b>"]

    subgraph PIPELINE["<b>Processing Pipeline</b>"]
        direction TB
        ORCH["<b>Orchestrator</b>"]
        PLAN["🤖 <b>PLANNER</b>"]
        EXEC["<b>PLAN_EXECUTOR</b>"]
        PRES["🤖 <b>PRESENTER</b>"]
    end

    subgraph AGENTS["<b>Agents</b> — all 🤖 LLM"]
        direction LR
        SA["<b>STUDENT_AGENT</b>"]
        RA["<b>RAG_AGENT</b>"]
        AA["<b>ADMIN_AGENT</b>"]
        PA["<b>PREDICT_AGENT</b>"]
    end

    subgraph MEMORY["<b>Memory</b>"]
        direction LR
        SB[("Supabase")]
        PC[("Pinecone")]
    end

    %% Main pipeline flow
    UI -->|"query"| ORCH
    ORCH --> PLAN
    PLAN --> EXEC
    EXEC --> PRES
    PRES -->|"response"| UI

    %% Agent dispatch and results back to executor
    EXEC -->|"dispatch + context"| AGENTS
    AGENTS -->|"results"| EXEC

    %% Agents read from memory
    SA & AA & PA -->|"read"| SB
    SA -->|"write"| SB
    RA -->|"search"| PC

    %% Orchestrator persists conversations
    ORCH -->|"save/load history"| SB

    %% Styling
    classDef llm fill:#E1BEE7,stroke:#8E24AA,stroke-width:2px,color:#4A148C
    classDef noLlm fill:#B2DFDB,stroke:#00897B,stroke-width:2px,color:#004D40
    classDef agent fill:#C8E6C9,stroke:#2E7D32,stroke-width:2px,color:#1B5E20
    classDef mem fill:#FFE0B2,stroke:#EF6C00,stroke-width:2px,color:#E65100
    classDef ui fill:#BBDEFB,stroke:#1565C0,stroke-width:3px,color:#0D47A1

    class PLAN,PRES llm
    class ORCH,EXEC noLlm
    class SA,RA,AA,PA agent
    class SB,PC mem
    class UI ui

    style PIPELINE fill:#FAFAFA,stroke:#B0BEC5,stroke-width:1px
    style AGENTS fill:#F1F8E9,stroke:#81C784,stroke-width:2px,stroke-dasharray:5 5
    style MEMORY fill:#FFF3E0,stroke:#FFB74D,stroke-width:2px,stroke-dasharray:5 5
