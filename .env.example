# Copy this file to .env and fill in your values

# LLMod.ai (required)
LLMOD_API_KEY=your_llmod_api_key_here
LLMOD_BASE_URL=https://api.llmod.ai/v1
LLMOD_CHAT_MODEL=RPRTHPB-gpt-5-mini
LLMOD_EMBEDDING_MODEL=RPRTHPB-text-embedding-3-small

# Supabase (required) — use the service_role key, not anon
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# Pinecone (required)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=co-teacher-memory
PINECONE_ENVIRONMENT=us-east-1

# Budget limits (optional — defaults shown)
BUDGET_LIMIT=13.00
BUDGET_WARNING_THRESHOLD=10.00

# Set to true to skip external services and use in-memory mocks (local dev only)
USE_MOCK_SERVICES=false

# Debug mode (optional — false in production)
DEBUG=false
